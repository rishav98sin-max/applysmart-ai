# ApplySmart AI — environment template
# Copy to `.env` and fill in real values. Never commit the populated `.env`.

# ─── Required ──────────────────────────────────────────────────────────────
# Primary LLM provider: Groq for fast tasks, Gemini for writing (CV tailoring, cover letters)
GROQ_API_KEY=gsk_your_primary_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email delivery — Gmail SMTP (app password).
# Generate at https://myaccount.google.com/apppasswords (requires 2FA on).
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password

# ─── Optional — Groq key rotation pool ─────────────────────────────────────
# Add up to 3 more keys from different Groq accounts. When one hits its
# per-minute or daily quota, the app auto-rotates. Ceiling ≈ 400K tokens/day
# with all 4 slots populated.
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# ─── Optional — DeepSeek V4 (recommended for CV tailoring quality) ─────────
# DeepSeek V4-Flash gives noticeably stronger instruction-following than
# Llama 3.3 70B for the cv_diff_tailor stage at ~$0.001 per call. With a
# key set here, the tailor tries DeepSeek first and falls back to
# Gemini→Groq automatically if anything fails. Without a key, behaviour is
# unchanged from the free-tier Groq path.
# Get a key at https://platform.deepseek.com (usually $5 free credit on signup).
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat   # default; = V4-Flash non-thinking (cheapest)
# DEEPSEEK_MODEL=deepseek-v4-pro # stronger reasoning, ~12× the cost

# ─── Optional — LangSmith tracing (consent-gated in-app) ───────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=applysmart-ai

# ─── Optional — job-board APIs (fallbacks to scraping when absent) ─────────
SERPAPI_KEY=
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# ─── Optional — product analytics (Mixpanel) ───────────────────────────────
# See docs/MIXPANEL_DASHBOARD.md for setup + live dashboard reference.
MIXPANEL_TOKEN=
MIXPANEL_REGION=US   # or EU — must match your Mixpanel project's residency

# ─── Optional — runtime knobs (see README §Configuration for full list) ────
# GROQ_MODEL=llama-3.3-70b-versatile
# MAX_LLM_CALLS_PER_RUN=60
# MAX_TAILOR_RETRIES=1
# REVIEWER_ACCEPT_THRESHOLD=72
# USE_VECTOR_RETRIEVAL=1
